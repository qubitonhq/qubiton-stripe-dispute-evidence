{
  "name": "qubiton-stripe-dispute-evidence",
  "version": "0.1.0",
  "private": true,
  "description": "Reference implementation: auto-build Stripe dispute evidence packets via webhook, enriched by the QubitOn API.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src tests --max-warnings 0",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@qubiton/sdk": "^1.1.1",
    "express": "^4.19.2",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.21",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "QubitOn <support@qubiton.com>",
  "license": "MIT",
  "keywords": [
    "stripe",
    "disputes",
    "chargebacks",
    "webhooks",
    "qubiton",
    "fraud-prevention"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qubitonhq/qubiton-stripe-dispute-evidence.git"
  },
  "bugs": {
    "url": "https://github.com/qubitonhq/qubiton-stripe-dispute-evidence/issues"
  },
  "homepage": "https://www.qubiton.com/blog/stripe-dispute-evidence-packet"
}
