# Stripe — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe — set this when you create the webhook endpoint or run `stripe listen`.
# `stripe listen` prints the signing secret on startup.
STRIPE_WEBHOOK_SECRET=whsec_...

# QubitOn — get a free key (100 calls/mo) at https://www.qubiton.com/auth/register
QUBITON_API_KEY=svm...

# Optional. Defaults to 3000.
PORT=3000

# Optional. Graceful-shutdown drain timeout in ms (default 30000).
# Must be <= your platform's terminationGracePeriodSeconds (Kubernetes /
# ECS / Fly / Render / etc.) — otherwise the platform SIGKILLs you mid-drain.
SHUTDOWN_TIMEOUT_MS=30000

# Optional. Port for the standalone checkout example (src/checkout-example.ts).
# Only used when RUN_CHECKOUT_EXAMPLE=1. Defaults to 3001.
CHECKOUT_EXAMPLE_PORT=3001
